:root {
  --font-heading-family: "Didot", "Playfair Display", serif;
  --font-body-family: "Inter", "Helvetica Neue", Arial, sans-serif;
  --color-bg: #ffffff;
  --color-text: #1a1a1a;
  --color-accent: #000000;
  --color-border: #e8e8e8;
  --spacing-unit: 8px;
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: var(--font-body-family);
  background: var(--color-bg);
  color: var(--color-text);
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3 { font-family: var(--font-heading-family); letter-spacing: -0.02em; }

.container { max-width: 1440px; margin: 0 auto; padding: 0 40px; }

/* Header */
.site-header {
  position: sticky;
  top: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  z-index: 100;
  border-bottom: 1px solid var(--color-border);
  padding: 24px 0;
}

.nav-list { display: flex; list-style: none; gap: 32px; margin: 0; padding: 0; text-transform: uppercase; font-size: 12px; letter-spacing: 0.1em; }
.nav-link { text-decoration: none; color: inherit; transition: var(--transition); }
.nav-link:hover { opacity: 0.6; }

/* Hero Banner */
.hero {
  position: relative;
  height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #f9f9f9;
}
.hero__content { text-align: center; max-width: 600px; z-index: 2; opacity: 0; transform: translateY(20px); animation: fadeInUp 1s forwards 0.5s; }
.hero__title { font-size: 4rem; margin-bottom: 1rem; }
.btn-primary { 
  display: inline-block;
  padding: 16px 40px;
  background: var(--color-accent);
  color: white;
  text-decoration: none;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  transition: var(--transition);
}
.btn-primary:hover { background: #333; transform: translateY(-2px); }

/* B2B Section */
.b2b-section { padding: 100px 0; background: #fafafa; }
.b2b-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.inquiry-form { display: flex; flex-direction: column; gap: 16px; }
.inquiry-form input, .inquiry-form textarea {
  padding: 16px;
  border: 1px solid var(--color-border);
  font-family: inherit;
}

/* Cart Drawer */
.cart-drawer {
  position: fixed;
  right: -400px;
  top: 0;
  width: 400px;
  height: 100%;
  background: white;
  box-shadow: -10px 0 30px rgba(0,0,0,0.05);
  transition: var(--transition);
  z-index: 1000;
  padding: 40px;
}
.cart-drawer.active { right: 0; }

@keyframes fadeInUp {
  to { opacity: 1; transform: translateY(0); }
}